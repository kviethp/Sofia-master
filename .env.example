# Sofia Master
SOFIA_API_PORT=8080
SOFIA_WEB_PORT=3000
SOFIA_ADMIN_PORT=3001
SOFIA_DATABASE_URL=postgres://sofia:sofia@127.0.0.1:5432/sofia
SOFIA_REDIS_URL=redis://127.0.0.1:6379
SOFIA_ARTIFACT_DIR=./.sofia/artifacts
SOFIA_LOG_LEVEL=info
SOFIA_TASK_QUEUE=sofia:runs
SOFIA_DEAD_LETTER_QUEUE=sofia:runs:dead-letter
SOFIA_WORKER_INLINE=true
SOFIA_EXECUTION_MODE=scaffold
SOFIA_REPORT_CHANNEL=disabled
SOFIA_REPORT_TARGET=
SOFIA_CONTROL_TOKEN=
SOFIA_SKILL_SOURCE_DIR=./skills
SOFIA_SKILL_OUTPUT_DIR=./.sofia/skills
SOFIA_SKILL_MANIFEST_PATH=./.sofia/skills/manifest.json
SOFIA_SKILL_AUTO_COMPILE=true
SOFIA_SKILL_TRUST_LEVELS=internal-trusted,reviewed-third-party
SOFIA_REQUIRED_RUNTIME_SKILLS=runtime-ops
SOFIA_OPENCLAW_COMMAND=openclaw
SOFIA_OPENCLAW_TIMEOUT_SECONDS=120
SOFIA_RUN_LEASE_SECONDS=90
SOFIA_RUN_HEARTBEAT_MS=
SOFIA_RUN_MAX_ATTEMPTS=3
SOFIA_RUN_BACKOFF_BASE_SECONDS=5
SOFIA_RUN_BACKOFF_MAX_SECONDS=60
SOFIA_DENY_PROVIDERS=
SOFIA_MAX_TOKENS_IN=
SOFIA_MAX_TOKENS_OUT=
SOFIA_MAX_TOKENS_TOTAL=
SOFIA_WORKER_LOOP=false
SOFIA_WORKER_IDLE_SLEEP_MS=1000
SOFIA_WORKER_POLL_INTERVAL_MS=1000
SOFIA_WORKER_MAX_ITERATIONS=1
SOFIA_APPROVAL_POLL_INTERVAL_MS=5000
SOFIA_APPROVAL_POLL_MAX_ITERATIONS=0
SOFIA_BACKUP_DIR=
SOFIA_BACKUP_LABEL=
SOFIA_RESTORE_SQL=
SOFIA_RESTORE_LOGICAL_JSON=

# 9Router
SOFIA_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
SOFIA_ROUTER_API_KEY=sk-sofia-local
SOFIA_ROUTER_MODELS_ENDPOINT=/models

# OpenClaw
SOFIA_OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
SOFIA_OPENCLAW_BASE_URL=http://127.0.0.1:18789
SOFIA_OPENCLAW_GATEWAY_TOKEN=
SOFIA_OPENCLAW_PROFILE=sofia-default

# Optional local-to-VPS tunnel helper
SOFIA_TUNNEL_HOST=
SOFIA_TUNNEL_PORT=
SOFIA_TUNNEL_USER=
SOFIA_TUNNEL_PASSWORD=
SOFIA_TUNNEL_HOSTKEY=
SOFIA_TUNNEL_FORWARDS=5432:127.0.0.1:5432,6379:127.0.0.1:6379,20128:127.0.0.1:20128,18789:127.0.0.1:18789
