FROM node:22-alpine

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev

COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts
COPY sql ./sql
COPY infra ./infra
COPY openapi ./openapi
COPY templates ./templates
COPY examples ./examples
COPY docs ./docs
COPY README.md CONTRIBUTING.md COMPATIBILITY.md SECURITY.md SUPPORT.md MODEL-POLICY.md CHANGELOG.md Makefile ./
COPY .env.example ./.env.example

ENV NODE_ENV=production

CMD ["node", "apps/sofia-api/src/index.js"]
