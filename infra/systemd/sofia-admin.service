[Unit]
Description=Sofia Admin
After=network.target sofia-api.service
Requires=sofia-api.service

[Service]
Type=simple
WorkingDirectory=/opt/sofia/current
EnvironmentFile=/etc/sofia/sofia.env
ExecStart=/usr/bin/env node apps/sofia-admin/src/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
